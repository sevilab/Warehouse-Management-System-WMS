<UserControl x:Class="WarehouseManagementSystem.Views.SupplierView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:converters="clr-namespace:WarehouseManagementSystem.Converters"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="#F5F5F5">
    <UserControl.Resources>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    </UserControl.Resources>
    
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Başlık -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="👥 Tedarikçi Yönetimi" FontSize="20" FontWeight="Bold" Foreground="#311B92"/>
            <Button Command="{Binding ExportCommand}"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Margin="20,0,0,0"
                    Foreground="#2E7D32"
                    ToolTip="Excel (CSV) Olarak Dışa Aktar">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="FileExport" VerticalAlignment="Center"/>
                    <TextBlock Text="Dışa Aktar" Margin="5,0,0,0"/>
                </StackPanel>
            </Button>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- Sol: Tedarikçi Listesi -->
            <Border Grid.Column="0" Background="White" CornerRadius="12"
                    Margin="0,0,15,0" Padding="20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" Opacity="0.1" ShadowDepth="2"/>
                </Border.Effect>
                <DockPanel>

                    <!-- Arama -->
                    <Border DockPanel.Dock="Top" Background="#F3E5F5"
                            CornerRadius="8" Padding="12,8" Margin="0,0,0,15">
                        <DockPanel>
                            <TextBlock Text="🔍" VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <TextBox Text="{Binding SearchKeyword,
                                     UpdateSourceTrigger=PropertyChanged}"
                                     BorderThickness="0" Background="Transparent"
                                     VerticalAlignment="Center" FontSize="14"/>
                        </DockPanel>
                    </Border>
                    <!-- Filtre Satırı -->
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <ComboBox Grid.Column="0" ItemsSource="{Binding StatusFilters}"
              SelectedItem="{Binding SelectedStatusFilter}"
              Margin="0,0,8,0" Padding="8,6"/>

                        <ComboBox Grid.Column="1" ItemsSource="{Binding SortOptions}"
              SelectedItem="{Binding SelectedSortOption}"
              Margin="0,0,8,0" Padding="8,6"/>

                        <Button Grid.Column="2" Content="🔄 Sıfırla"
            Command="{Binding ClearFiltersCommand}"
            Background="#757575" Foreground="White"
            BorderThickness="0" Padding="12,6"
            Cursor="Hand"/>
                    </Grid>

                    <!-- Sonuç Sayısı -->
                    <TextBlock DockPanel.Dock="Top"
           Text="{Binding ResultCount, StringFormat='{}{0} tedarikçi listeleniyor'}"
           Foreground="#9E9E9E" FontSize="12" Margin="0,0,0,8"/>

                    <!-- Tablo Başlığı -->
                    <Grid x:Name="SupplierHeaderGrid" DockPanel.Dock="Top" Margin="10,0,10,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="FİRMA ADI"
                                   FontSize="11" FontWeight="Bold" Foreground="#9E9E9E"/>
                        <TextBlock Grid.Column="1" Text="İLETİŞİM KİŞİSİ"
                                   FontSize="11" FontWeight="Bold" Foreground="#9E9E9E"/>
                        <TextBlock Grid.Column="2" Text="TELEFON"
                                   FontSize="11" FontWeight="Bold" Foreground="#9E9E9E"/>
                        <TextBlock Grid.Column="3" Text="DURUM"
                                   FontSize="11" FontWeight="Bold" Foreground="#9E9E9E"/>
                    </Grid>

                    <Separator DockPanel.Dock="Top" Margin="0,0,0,8"/>

                    <!-- Liste -->
                    <ListView ItemsSource="{Binding Suppliers}"
                              SelectedItem="{Binding SelectedSupplier}"
                              BorderThickness="0"
                              HorizontalContentAlignment="Stretch"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0,8"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#F5F5F5"/>
                                <EventSetter Event="MouseLeftButtonUp"
                                             Handler="ListViewItem_Click"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Width="{Binding ActualWidth, ElementName=SupplierHeaderGrid}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Name}"
                                                   FontWeight="SemiBold"
                                                   Foreground="#212121"/>
                                        <TextBlock Text="{Binding Email}"
                                                   FontSize="11" Foreground="#9E9E9E"/>
                                    </StackPanel>

                                    <TextBlock Grid.Column="1"
                                               Text="{Binding ContactPerson}"
                                               Foreground="#616161"
                                               VerticalAlignment="Center"/>

                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Phone}"
                                               Foreground="#616161"
                                               VerticalAlignment="Center"/>

                                    <Border Grid.Column="3" CornerRadius="12"
                                            Padding="8,3" VerticalAlignment="Center"
                                            HorizontalAlignment="Left">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#E8F5E9"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}"
                                                                 Value="False">
                                                        <Setter Property="Background" Value="#FFEBEE"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock FontSize="11" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="Aktif"/>
                                                    <Setter Property="Foreground" Value="#2E7D32"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}"
                                                                     Value="False">
                                                            <Setter Property="Text" Value="Pasif"/>
                                                            <Setter Property="Foreground" Value="#C62828"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Durum -->
                    <TextBlock DockPanel.Dock="Bottom"
                               Text="{Binding StatusMessage}"
                               Foreground="#4527A0" FontSize="13"
                               Margin="0,10,0,0"/>
                </DockPanel>
            </Border>

            <!-- Sağ: Form -->
            <Border Grid.Column="1" Background="White" CornerRadius="12"
                    Padding="20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" Opacity="0.1" ShadowDepth="2"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Tedarikçi İşlemleri" FontSize="16"
                               FontWeight="SemiBold" Foreground="#311B92"
                               Margin="0,0,0,20"/>

                    <TextBlock Text="Firma Adı" Foreground="#757575"
                               FontSize="12" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding FormName, UpdateSourceTrigger=PropertyChanged}"
                             Padding="10,8" BorderBrush="#E0E0E0"
                             BorderThickness="1" Margin="0,0,0,12"/>

                    <TextBlock Text="İletişim Kişisi" Foreground="#757575"
                               FontSize="12" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding FormContactPerson,
                             UpdateSourceTrigger=PropertyChanged}"
                             Padding="10,8" BorderBrush="#E0E0E0"
                             BorderThickness="1" Margin="0,0,0,12"/>

                    <TextBlock Text="E-Posta" Foreground="#757575"
                               FontSize="12" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding FormEmail, UpdateSourceTrigger=PropertyChanged}"
                             Padding="10,8" BorderBrush="#E0E0E0"
                             BorderThickness="1" Margin="0,0,0,12"/>

                    <TextBlock Text="Telefon" Foreground="#757575"
                               FontSize="12" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding FormPhone, UpdateSourceTrigger=PropertyChanged}"
                             Padding="10,8" BorderBrush="#E0E0E0"
                             BorderThickness="1" Margin="0,0,0,12"/>

                  <TextBlock Text="Adres" Foreground="#757575"
                               FontSize="12" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding FormAddress, UpdateSourceTrigger=PropertyChanged}"
                             Padding="10,8" BorderBrush="#E0E0E0"
                             BorderThickness="1" Margin="0,0,0,12"
                             TextWrapping="Wrap" Height="70"
                             AcceptsReturn="True"/>

                    <CheckBox IsChecked="{Binding FormIsActive}"
                              Content="Aktif Tedarikçi"
                              Foreground="#212121" FontWeight="SemiBold"
                              Margin="0,0,0,20" Cursor="Hand"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="➕ Ekle"
                                Command="{Binding AddSupplierCommand}"
                                IsEnabled="{Binding IsAdmin}"
                                Background="#4527A0" Foreground="White"
                                BorderThickness="0" Padding="0,10"
                                Margin="0,0,5,0" Cursor="Hand"/>
                        <Button Grid.Column="1" Content="✏️ Güncelle"
                                Command="{Binding UpdateSupplierCommand}"
                                IsEnabled="{Binding IsAdmin}"
                                Background="#1565C0" Foreground="White"
                                BorderThickness="0" Padding="0,10"
                                Margin="5,0,0,0" Cursor="Hand"/>
                    </Grid>

                    <Button Content="🗑️ Sil" Margin="0,8,0,0"
                            Command="{Binding DeleteSupplierCommand}"
                            IsEnabled="{Binding IsAdmin}"
                            Background="#C62828" Foreground="White"
                            BorderThickness="0" Padding="0,10"
                            Cursor="Hand"/>
                    <Button Content="🔄 Temizle" Margin="0,8,0,0"
                            Command="{Binding ClearFormCommand}"
                            Background="#757575" Foreground="White"
                            BorderThickness="0" Padding="0,10"
                            Cursor="Hand"/>
                    <Border CornerRadius="8" Padding="12,8" Margin="0,12,0,0"
                            Visibility="{Binding StatusMessage,
                        Converter={StaticResource StringToVisibilityConverter}}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#E8F5E9"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsStatusError}" Value="True">
                                        <Setter Property="Background" Value="#FFEBEE"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding StatusMessage}" FontSize="13" TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#2E7D32"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsStatusError}" Value="True">
                                            <Setter Property="Foreground" Value="#C62828"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>

                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>