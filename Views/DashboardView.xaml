<UserControl x:Class="WarehouseManagementSystem.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="#F5F5F5">

    <materialDesign:DialogHost IsOpen="{Binding IsOrderDialogOpen}"
                               CloseOnClickAway="True">
        <!-- Sipariş Formu (Dialog İçeriği) -->
        <materialDesign:DialogHost.DialogContent>
            <Border Padding="25" Width="400" Background="White">
                <StackPanel>
                    <TextBlock Text="🛒 Yeni Satın Alma Siparişi" 
                               FontSize="18" FontWeight="Bold" 
                               Margin="0,0,0,15" Foreground="#311B92"/>
                    
                    <TextBlock Text="Ürün:" FontWeight="SemiBold" Margin="0,5,0,2"/>
                    <TextBlock Text="{Binding OrderProduct.Name}" Margin="0,0,0,15" FontSize="14" Foreground="#424242"/>

                    <TextBlock Text="Tedarikçi Seçimi:" FontWeight="SemiBold" Margin="0,5,0,2"/>
                    <ComboBox ItemsSource="{Binding Suppliers}"
                              SelectedItem="{Binding SelectedSupplier}"
                              DisplayMemberPath="Name"
                              materialDesign:HintAssist.Hint="Tedarikçi Seçin"
                              Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                              Margin="0,0,0,15"/>

                    <TextBox materialDesign:HintAssist.Hint="Birim Fiyat (₺)"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                             Text="{Binding OrderUnitPriceText, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,15"
                             x:Name="OrderUnitPriceBox"/>

                    <TextBox materialDesign:HintAssist.Hint="Sipariş Miktarı"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                             Text="{Binding OrderQuantityText, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,20"
                             x:Name="OrderQuantityBox"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="İPTAL" Style="{StaticResource MaterialDesignFlatButton}"
                                Command="{Binding CloseOrderDialogCommand}" Margin="0,0,8,0"/>
                        <Button Content="SİPARİŞ VER" 
                                Command="{Binding SaveOrderCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </materialDesign:DialogHost.DialogContent>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="25">

                <!-- Başlık -->
                <TextBlock Text="📊 Dashboard" FontSize="22"
                           FontWeight="Bold" Foreground="#311B92"
                           Margin="0,0,0,20"/>

                <!-- Üst Kartlar -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="White" CornerRadius="12" Margin="0,0,8,0" Padding="16">
                        <Border.Effect><DropShadowEffect BlurRadius="10" Opacity="0.1" ShadowDepth="2"/></Border.Effect>
                        <StackPanel>
                            <TextBlock Text="📦" FontSize="24"/>
                            <TextBlock Text="{Binding TotalProducts}" FontSize="28" FontWeight="Bold" Foreground="#4527A0" Margin="0,6,0,4"/>
                            <TextBlock Text="Toplam Ürün" Foreground="#757575" FontSize="11"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="White" CornerRadius="12" Margin="4,0,4,0" Padding="16">
                        <Border.Effect><DropShadowEffect BlurRadius="10" Opacity="0.1" ShadowDepth="2"/></Border.Effect>
                        <StackPanel>
                            <TextBlock Text="💰" FontSize="24"/>
                            <TextBlock Text="{Binding TotalStockValueDecimal, StringFormat='₺{0:N0}'}" FontSize="20" FontWeight="Bold" Foreground="#2E7D32" Margin="0,6,0,4"/>
                            <TextBlock Text="Stok Değeri" Foreground="#757575" FontSize="11"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Background="White" CornerRadius="12" Margin="4,0,4,0" Padding="16">
                        <Border.Effect><DropShadowEffect BlurRadius="10" Opacity="0.1" ShadowDepth="2"/></Border.Effect>
                        <StackPanel>
                            <TextBlock Text="🏢" FontSize="24"/>
                            <TextBlock Text="{Binding TotalSuppliers}" FontSize="28" FontWeight="Bold" Foreground="#1565C0" Margin="0,6,0,4"/>
                            <TextBlock Text="Tedarikçi" Foreground="#757575" FontSize="11"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="3" Background="White" CornerRadius="12" Margin="4,0,4,0" Padding="16">
                        <Border.Effect><DropShadowEffect BlurRadius="10" Opacity="0.1" ShadowDepth="2"/></Border.Effect>
                        <StackPanel>
                            <TextBlock Text="📋" FontSize="24"/>
                            <TextBlock Text="{Binding TotalTransactions}" FontSize="28" FontWeight="Bold" Foreground="#00838F" Margin="0,6,0,4"/>
                            <TextBlock Text="İşlem Sayısı" Foreground="#757575" FontSize="11"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="4" Background="White" CornerRadius="12" Margin="4,0,4,0" Padding="16">
                        <Border.Effect><DropShadowEffect BlurRadius="10" Opacity="0.1" ShadowDepth="2"/></Border.Effect>
                        <StackPanel>
                            <TextBlock Text="⚠️" FontSize="24"/>
                            <TextBlock Text="{Binding LowStockCount}" FontSize="28" FontWeight="Bold" Foreground="#F57F17" Margin="0,6,0,4"/>
                            <TextBlock Text="Düşük Stok" Foreground="#757575" FontSize="11"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="5" Background="White" CornerRadius="12" Margin="8,0,0,0" Padding="16">
                        <Border.Effect><DropShadowEffect BlurRadius="10" Opacity="0.1" ShadowDepth="2"/></Border.Effect>
                        <StackPanel>
                            <TextBlock Text="🔴" FontSize="24"/>
                            <TextBlock Text="{Binding CriticalStockCount}" FontSize="28" FontWeight="Bold" Foreground="#C62828" Margin="0,6,0,4"/>
                            <TextBlock Text="Kritik Stok" Foreground="#757575" FontSize="11"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Alt Bölüm - Düşük Stok -->
                <Border Background="White" CornerRadius="12" Padding="20">
                    <Border.Effect><DropShadowEffect BlurRadius="10" Opacity="0.1" ShadowDepth="2"/></Border.Effect>
                    <StackPanel>
                        <TextBlock Text="⚠️ Düşük Stok Uyarıları" FontSize="16" FontWeight="SemiBold" Foreground="#311B92" Margin="0,0,0,15"/>
                        <ItemsControl ItemsSource="{Binding LowStockProducts}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#FFF8E1" CornerRadius="8" Padding="12,8" Margin="0,0,0,8">
                                        <DockPanel>
                                            <Button DockPanel.Dock="Right" 
                                                    Content="Sipariş Oluştur" 
                                                    FontSize="10" 
                                                    Padding="8,2" 
                                                    Height="25"
                                                    Command="{Binding DataContext.OpenOrderDialogCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource MaterialDesignOutlinedButton}"/>
                                            
                                            <TextBlock Text="{Binding StockQuantity, StringFormat='Stok: {0}'}"
                                                       DockPanel.Dock="Right"
                                                       Margin="0,0,15,0"
                                                       VerticalAlignment="Center"
                                                       Foreground="#F57F17"
                                                       FontWeight="Bold"/>
                                            
                                            <TextBlock Text="{Binding Name}"
                                                       VerticalAlignment="Center"
                                                       Foreground="#424242"
                                                       FontWeight="SemiBold"/>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        
                        <TextBlock Text="Tüm stoklar normal seviyede 🎉" Foreground="#9E9E9E" FontSize="13" HorizontalAlignment="Center" Margin="0,10,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding LowStockCount}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </materialDesign:DialogHost>
</UserControl>