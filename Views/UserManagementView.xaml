<UserControl x:Class="WarehouseManagementSystem.Views.UserManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:WarehouseManagementSystem.Converters"
             Background="#F5F5F5">

    <UserControl.Resources>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="👥 Kullanıcı Yönetimi" FontSize="22"
                   FontWeight="Bold" Foreground="#311B92" Margin="0,0,0,20"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- Sol: Kullanıcı Listesi -->
            <Border Grid.Column="0" Background="White" CornerRadius="12"
                    Margin="0,0,15,0" Padding="20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" Opacity="0.1" ShadowDepth="2"/>
                </Border.Effect>
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="KULLANICI ADI"
                                   FontSize="11" FontWeight="Bold" Foreground="#9E9E9E"/>
                        <TextBlock Grid.Column="1" Text="AD SOYAD"
                                   FontSize="11" FontWeight="Bold" Foreground="#9E9E9E"/>
                        <TextBlock Grid.Column="2" Text="ROL"
                                   FontSize="11" FontWeight="Bold" Foreground="#9E9E9E"/>
                    </Grid>

                    <Separator DockPanel.Dock="Top" Margin="0,0,0,8"/>

                    <ListView ItemsSource="{Binding Users}"
                              SelectedItem="{Binding SelectedUser}"
                              BorderThickness="0"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0,8"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#F5F5F5"/>
                                <Setter Property="Cursor" Value="Hand"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Username}"
                                                   FontWeight="SemiBold" Foreground="#212121"/>
                                        <TextBlock Text="{Binding CreatedAt,
                                                   StringFormat='Eklenme: {0:dd.MM.yyyy}'}"
                                                   FontSize="11" Foreground="#9E9E9E"/>
                                    </StackPanel>

                                    <TextBlock Grid.Column="1"
                                               Text="{Binding FullName}"
                                               Foreground="#616161"
                                               VerticalAlignment="Center"/>

                                    <Border Grid.Column="2" CornerRadius="12"
                                            Padding="8,3" VerticalAlignment="Center"
                                            HorizontalAlignment="Left">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#E8EAF6"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Role}"
                                                                 Value="Admin">
                                                        <Setter Property="Background" Value="#EDE7F6"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Role}"
                                                   FontSize="11" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#3949AB"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Role}"
                                                                     Value="Admin">
                                                            <Setter Property="Foreground" Value="#4527A0"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </DockPanel>
            </Border>

            <!-- Sağ: Form -->
            <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" Opacity="0.1" ShadowDepth="2"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Kullanıcı İşlemleri" FontSize="16"
                               FontWeight="SemiBold" Foreground="#311B92"
                               Margin="0,0,0,20"/>

                    <TextBlock Text="Kullanıcı Adı *" Foreground="#757575"
                               FontSize="12" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding FormUsername, UpdateSourceTrigger=PropertyChanged}"
                             Padding="10,8" Margin="0,0,0,12"/>

                    <TextBlock Text="Ad Soyad *" Foreground="#757575"
                               FontSize="12" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding FormFullName, UpdateSourceTrigger=PropertyChanged}"
                             Padding="10,8" Margin="0,0,0,12"/>

                    <TextBlock Text="Şifre *" Foreground="#757575"
                               FontSize="12" Margin="0,0,0,4"/>
                    <PasswordBox x:Name="PasswordBox"
                                 Padding="10,8" Margin="0,0,0,12"
                                 PasswordChanged="PasswordBox_Changed"/>

                    <TextBlock Text="Rol" Foreground="#757575"
                               FontSize="12" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding Roles}"
                              SelectedItem="{Binding FormRole}"
                              Padding="10,8" Margin="0,0,0,20"/>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="➕ Ekle"
                                Command="{Binding AddUserCommand}"
                                Background="#4527A0" Foreground="White"
                                BorderThickness="0" Padding="0,10"
                                Margin="0,0,5,0" Cursor="Hand"/>
                        <Button Grid.Column="1" Content="🗑️ Sil"
                                Command="{Binding DeleteUserCommand}"
                                Background="#C62828" Foreground="White"
                                BorderThickness="0" Padding="0,10"
                                Margin="5,0,0,0" Cursor="Hand"/>
                    </Grid>

                    <Button Content="🔑 Şifre Değiştir"
                            Command="{Binding ChangePasswordCommand}"
                            Background="#1565C0" Foreground="White"
                            BorderThickness="0" Padding="0,10"
                            Margin="0,0,0,8" Cursor="Hand"/>

                    <Button Content="🔄 Temizle"
                            Command="{Binding ClearFormCommand}"
                            Background="#757575" Foreground="White"
                            BorderThickness="0" Padding="0,10"
                            Cursor="Hand"/>

                    <!-- Durum Mesajı -->
                    <Border CornerRadius="8" Padding="12,8" Margin="0,12,0,0"
                            Visibility="{Binding StatusMessage,
                                         Converter={StaticResource StringToVisibilityConverter}}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#E8F5E9"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsStatusError}" Value="True">
                                        <Setter Property="Background" Value="#FFEBEE"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding StatusMessage}"
                                   FontSize="13" TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#2E7D32"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsStatusError}" Value="True">
                                            <Setter Property="Foreground" Value="#C62828"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>