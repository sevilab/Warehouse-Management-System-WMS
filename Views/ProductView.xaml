<UserControl x:Class="WarehouseManagementSystem.Views.ProductView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="#F5F5F5"
             xmlns:converters="clr-namespace:WarehouseManagementSystem.Converters">
    <UserControl.Resources>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    </UserControl.Resources>
    
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="📦 Ürün Yönetimi" FontSize="20" FontWeight="Bold" Foreground="#311B92"/>
            <Button Command="{Binding ExportCommand}"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Margin="20,0,0,0"
                    Foreground="#2E7D32"
                    ToolTip="Excel (CSV) Olarak Dışa Aktar">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="FileExport" VerticalAlignment="Center"/>
                    <TextBlock Text="Dışa Aktar" Margin="5,0,0,0"/>
                </StackPanel>
            </Button>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="360"/>
            </Grid.ColumnDefinitions>

            <!-- Sol: Ürün Listesi -->
            <Border Grid.Column="0" Background="White" CornerRadius="12"
                    Margin="0,0,15,0" Padding="20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" Opacity="0.1" ShadowDepth="2"/>
                </Border.Effect>
                <DockPanel>

                    <!-- Hızlı Ürün Bul (Dashboard'dan Taşındı) -->
                    <Border DockPanel.Dock="Top" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" 
                            CornerRadius="8" Padding="15,10" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="🔎 Hızlı Ürün Bul &amp; Lokasyon Sorgula" FontSize="14" FontWeight="SemiBold" Foreground="#311B92" Margin="0,0,0,10"/>
                            <TextBox materialDesign:HintAssist.Hint="Ürün Adı veya SKU ile Ara..."
                                     materialDesign:TextFieldAssist.HasClearButton="True"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,10" Height="40" Padding="10,5"
                                     x:Name="GlobalSearchBox"/>

                            <ListBox ItemsSource="{Binding SearchResults}" MaxHeight="200" 
                                     BorderThickness="0" Background="#FAFAFA" Margin="0,0,0,0">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#EEEEEE" BorderThickness="0,0,0,1" Padding="8,5">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="130"/>
                                                    <ColumnDefinition Width="100"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding ProductName}" FontWeight="Bold" FontSize="12" Foreground="#212121"/>
                                                    <TextBlock Text="{Binding SKU}" FontSize="10" Foreground="#757575"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <Border Background="#F3E5F5" CornerRadius="4" Padding="4,1" HorizontalAlignment="Left">
                                                        <TextBlock Text="{Binding LocationInfo}" Foreground="#7B1FA2" FontWeight="Bold" FontSize="10"/>
                                                    </Border>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                                    <TextBlock Text="{Binding Stock}" FontWeight="Bold" Foreground="#2E7D32" FontSize="12"/>
                                                    <TextBlock Text="{Binding Size}" FontSize="9" Foreground="#757575" HorizontalAlignment="Right"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                                <ListBox.Style>
                                    <Style TargetType="ListBox">
                                        <Style.Triggers>
                                            <Trigger Property="HasItems" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.Style>
                            </ListBox>
                        </StackPanel>
                    </Border>


                    <!-- Filtre Satırı -->
<Grid DockPanel.Dock="Top" Margin="0,0,0,12">
    <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
    </Grid.ColumnDefinitions>

    <ComboBox Grid.Column="0" ItemsSource="{Binding CategoryFilters}"
              SelectedItem="{Binding SelectedCategoryFilter}"
              Margin="0,0,8,0" Padding="8,6"/>

    <ComboBox Grid.Column="1" ItemsSource="{Binding StockFilters}"
              SelectedItem="{Binding SelectedStockFilter}"
              Margin="0,0,8,0" Padding="8,6"/>

    <ComboBox Grid.Column="2" ItemsSource="{Binding SortOptions}"
              SelectedItem="{Binding SelectedSortOption}"
              Margin="0,0,8,0" Padding="8,6"/>

    <Button Grid.Column="3" Content="🔄 Sıfırla"
            Command="{Binding ClearFiltersCommand}"
            Background="#757575" Foreground="White"
            BorderThickness="0" Padding="12,6"
            Cursor="Hand"/>
</Grid>

<!-- Sonuç Sayısı -->
<TextBlock DockPanel.Dock="Top"
           Text="{Binding ResultCount, StringFormat='{}{0} ürün listeleniyor'}"
           Foreground="#9E9E9E" FontSize="12" Margin="0,0,0,8"/>

                    <!-- Tablo Başlığı -->
                    <Grid x:Name="ProductHeaderGrid" DockPanel.Dock="Top" Margin="10,0,10,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="70"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="ÜRÜN ADI / SKU" FontSize="11" FontWeight="Bold" Foreground="#9E9E9E"/>
                        <TextBlock Grid.Column="1" Text="TEDARİKÇİ" FontSize="11" FontWeight="Bold" Foreground="#9E9E9E"/>
                        <TextBlock Grid.Column="2" Text="KATEGORİ" FontSize="11" FontWeight="Bold" Foreground="#9E9E9E"/>
                        <TextBlock Grid.Column="3" Text="RENK / BEDEN" FontSize="11" FontWeight="Bold" Foreground="#9E9E9E"/>
                        <TextBlock Grid.Column="4" Text="LOKASYON" FontSize="11" FontWeight="Bold" Foreground="#9E9E9E"/>
                        <TextBlock Grid.Column="5" Text="STOK" FontSize="11" FontWeight="Bold" Foreground="#9E9E9E"/>
                        <TextBlock Grid.Column="6" Text="FİYAT" FontSize="11" FontWeight="Bold" Foreground="#9E9E9E"/>
                        <TextBlock Grid.Column="7" Text="DURUM" FontSize="11" FontWeight="Bold" Foreground="#9E9E9E"/>
                    </Grid>

                    <Separator DockPanel.Dock="Top" Margin="0,0,0,8"/>

                    <!-- Liste -->
                    <ListView ItemsSource="{Binding Products}"
                              SelectedItem="{Binding SelectedProduct}"
                              BorderThickness="0"
                              HorizontalContentAlignment="Stretch"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0,8"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#F5F5F5"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <EventSetter Event="MouseLeftButtonUp"
                                             Handler="ListViewItem_Click"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Width="{Binding ActualWidth, ElementName=ProductHeaderGrid}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.5*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="70"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="#212121"/>
                                        <TextBlock Text="{Binding SKU}" FontSize="11" Foreground="#9E9E9E"/>
                                    </StackPanel>

                                    <TextBlock Grid.Column="1" Text="{Binding SupplierName}"
                                               Foreground="#4527A0" VerticalAlignment="Center" FontSize="12" TextTrimming="CharacterEllipsis"/>

                                    <TextBlock Grid.Column="2" Text="{Binding Category}" Foreground="#616161" FontSize="12" VerticalAlignment="Center"/>

                                    <StackPanel Grid.Column="3" VerticalAlignment="Center" Orientation="Horizontal">
                                        <TextBlock Text="{Binding Color}" Foreground="#616161" FontSize="12"/>
                                        <TextBlock Text="/" Foreground="#BDBDBD" FontSize="12" Margin="3,0"/>
                                        <TextBlock Text="{Binding Size}" Foreground="#616161" FontSize="12"/>
                                    </StackPanel>

                                    <Border Grid.Column="4" Background="#F3E5F5" CornerRadius="4" 
                                            Padding="6,2" HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding LocationName}" FontSize="11" Foreground="#7B1FA2"/>
                                    </Border>

                                    <TextBlock Grid.Column="5" VerticalAlignment="Center">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}{0} {1}">
                                                <Binding Path="StockQuantity"/>
                                                <Binding Path="Unit"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>

                                    <TextBlock Grid.Column="6"
                                               Text="{Binding Price, StringFormat='₺{0:N2}'}"
                                               Foreground="#4527A0" FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>

                                    <Border Grid.Column="7" CornerRadius="12"
                                            Padding="8,3" VerticalAlignment="Center"
                                            HorizontalAlignment="Left">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#E8F5E9"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding AlertLevel}" Value="Düşük">
                                                        <Setter Property="Background" Value="#FFF8E1"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding AlertLevel}" Value="Kritik">
                                                        <Setter Property="Background" Value="#FFEBEE"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock FontSize="11" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="Normal"/>
                                                    <Setter Property="Foreground" Value="#2E7D32"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding AlertLevel}" Value="Düşük">
                                                            <Setter Property="Text" Value="Düşük"/>
                                                            <Setter Property="Foreground" Value="#F57F17"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding AlertLevel}" Value="Kritik">
                                                            <Setter Property="Text" Value="Kritik"/>
                                                            <Setter Property="Foreground" Value="#C62828"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Durum Mesajı -->
                    <Border DockPanel.Dock="Bottom" CornerRadius="8"
                            Padding="12,8" Margin="0,10,0,0"
                            Visibility="{Binding StatusMessage,
                                         Converter={StaticResource StringToVisibilityConverter}}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#E8F5E9"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsStatusError}" Value="True">
                                        <Setter Property="Background" Value="#FFEBEE"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding StatusMessage}" FontSize="13"
                                   TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#2E7D32"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsStatusError}" Value="True">
                                            <Setter Property="Foreground" Value="#C62828"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                </DockPanel>
            </Border>

            <!-- Sağ: Form -->
            <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" Opacity="0.1" ShadowDepth="2"/>
                </Border.Effect>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Ürün İşlemleri" FontSize="16"
                                   FontWeight="SemiBold" Foreground="#311B92"
                                   Margin="0,0,0,20"/>

                        <TextBlock Text="Ürün Adı *" Foreground="#757575" FontSize="12" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding FormName, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="10,8" Margin="0,0,0,12"/>

                        <TextBlock Text="SKU Kodu *" Foreground="#757575" FontSize="12" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding FormSKU, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="10,8" Margin="0,0,0,12"/>

                        <TextBlock Text="Fiyat (₺) *" Foreground="#757575" FontSize="12" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding FormPriceText, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="10,8" Margin="0,0,0,12"
                                 x:Name="FormPriceBox"/>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                <TextBlock Text="Renk" Foreground="#757575" FontSize="12" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding FormColor, UpdateSourceTrigger=PropertyChanged}" Padding="10,8"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                <TextBlock Text="Beden" Foreground="#757575" FontSize="12" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding FormSize, UpdateSourceTrigger=PropertyChanged}" Padding="10,8"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Min. Stok Seviyesi" Foreground="#757575" FontSize="12" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding FormMinStockText, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="10,8" Margin="0,0,0,12"/>

                        <TextBlock Text="Kategori" Foreground="#757575" FontSize="12" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding Categories}"
                                  SelectedItem="{Binding FormCategory}"
                                  Padding="10,8" Margin="0,0,0,12"/>

                        <TextBlock Text="Tedarikçi *" Foreground="#757575" FontSize="12" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding Suppliers}"
                                  SelectedItem="{Binding FormSupplier}"
                                  DisplayMemberPath="Name"
                                  Padding="10,8" Margin="0,0,0,12"/>

                        <TextBlock Text="Lokasyon" Foreground="#757575" FontSize="12" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding LocationsSet}"
                                  SelectedItem="{Binding SelectedLocation}"
                                  DisplayMemberPath="DisplayName"
                                  Padding="10,8" Margin="0,0,0,12"/>

                        <TextBlock Text="Birim" Foreground="#757575" FontSize="12" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding FormUnit, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="10,8" Margin="0,0,0,12"/>

                        <TextBlock Text="Açıklama" Foreground="#757575" FontSize="12" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding FormDescription, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="10,8" Margin="0,0,0,20"
                                 TextWrapping="Wrap" Height="60" AcceptsReturn="True"/>

                        <!-- Butonlar -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="➕ Ekle"
                                    Command="{Binding AddProductCommand}"
                                    Background="#4527A0" Foreground="White"
                                    BorderThickness="0" Padding="0,10"
                                    Margin="0,0,5,0" Cursor="Hand"
                                    IsEnabled="{Binding IsAdmin}"/>
                            <Button Grid.Column="1" Content="✏️ Güncelle"
                                    Command="{Binding UpdateProductCommand}"
                                    Background="#1565C0" Foreground="White"
                                    BorderThickness="0" Padding="0,10"
                                    Margin="5,0,0,0" Cursor="Hand"
                                    IsEnabled="{Binding IsAdmin}"/>
                        </Grid>

                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="🗑️ Sil"
                                    Command="{Binding DeleteProductCommand}"
                                    Background="#C62828" Foreground="White"
                                    BorderThickness="0" Padding="0,10"
                                    Margin="0,0,5,0" Cursor="Hand"
                                    IsEnabled="{Binding IsAdmin}"/>
                            <Button Grid.Column="1" Content="🔄 Temizle"
                                    Command="{Binding ClearFormCommand}"
                                    Background="#757575" Foreground="White"
                                    BorderThickness="0" Padding="0,10"
                                    Margin="5,0,0,0" Cursor="Hand"
                                  />
                        </Grid>

                        <Separator Margin="0,0,0,20"/>

                        <!-- Stok İşlemleri -->
                        <TextBlock Text="Stok İşlemleri" FontSize="14"
                                   FontWeight="SemiBold" Foreground="#311B92"
                                   Margin="0,0,0,12"/>

                        <TextBlock Text="Miktar *" Foreground="#757575" FontSize="12" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding StockQuantityText, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="10,8" Margin="0,0,0,12"
                                 x:Name="StockInQuantityBox"/>

                        <TextBlock Text="Birim Fiyat (₺)" Foreground="#757575" FontSize="12" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding StockUnitPriceText, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="10,8" Margin="0,0,0,12"/>

                        <TextBlock Text="Açıklama" Foreground="#757575" FontSize="12" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding StockDescription, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="10,8" Margin="0,0,0,12"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="📥 Giriş"
                                    Command="{Binding StockInCommand}"
                                    Background="#2E7D32" Foreground="White"
                                    BorderThickness="0" Padding="0,10"
                                    Margin="0,0,5,0" Cursor="Hand"/>
                            <Button Grid.Column="1" Content="📤 Çıkış"
                                    Command="{Binding StockOutCommand}"
                                    Background="#C62828" Foreground="White"
                                    BorderThickness="0" Padding="0,10"
                                    Margin="5,0,0,0" Cursor="Hand"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>