<UserControl x:Class="WarehouseManagementSystem.Views.PurchaseOrderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="#F5F5F5">
    
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Üst Panel: Başlık ve Filtre -->
        <DockPanel Grid.Row="0" Margin="0,0,0,20">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="🛒 Satın Alma Sipariş Takibi" FontSize="22" FontWeight="Bold" Foreground="#311B92"/>
                <TextBlock Text="Düşük stoklar için oluşturulan siparişleri buradan yönetebilirsiniz." Foreground="#757575" FontSize="12"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <CheckBox Content="Sadece Bekleyenler" 
                          IsChecked="{Binding ShowOnlyPending}" 
                          Margin="0,0,20,0"
                          Style="{StaticResource MaterialDesignActionLightCheckBox}"/>
                
                <Button Content="YENİLE" 
                        Command="{Binding RefreshCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Padding="15,0"/>
            </StackPanel>
        </DockPanel>

        <!-- Sipariş Listesi -->
        <materialDesign:Card Grid.Row="1" UniformCornerRadius="12" Padding="0">
            <DataGrid ItemsSource="{Binding Orders}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      Background="Transparent"
                      BorderThickness="0"
                      GridLinesVisibility="None">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="TARİH" Binding="{Binding CreatedAt, StringFormat='dd.MM.yyyy HH:mm'}" Width="150"/>
                    <DataGridTextColumn Header="ÜRÜN" Binding="{Binding ProductName}" Width="*"/>
                    <DataGridTextColumn Header="TEDARİKÇİ" Binding="{Binding SupplierName}" Width="*"/>
                    <DataGridTextColumn Header="BİRİM FİYAT" Binding="{Binding UnitPrice, StringFormat='₺{0:N2}'}" Width="110"/>
                    <DataGridTextColumn Header="MİKTAR" Binding="{Binding Quantity}" Width="80"/>
                    
                    <DataGridTemplateColumn Header="DURUM" Width="130">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="12" Padding="8,2" HorizontalAlignment="Left">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#FFF3E0"/> <!-- Bekliyor turuncu -->
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="TeslimAlindi">
                                                    <Setter Property="Background" Value="#E8F5E9"/> <!-- Teslim Yeşil -->
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Status}" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#EF6C00"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="TeslimAlindi">
                                                        <Setter Property="Foreground" Value="#2E7D32"/>
                                                        <Setter Property="Text" Value="Teslim Alındı"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Bekliyor">
                                                        <Setter Property="Text" Value="Bekliyor"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="İŞLEMLER" Width="150">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Command="{Binding DataContext.ReceiveOrderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="Teslim Alındı Olarak İşaretle ve Stoğa Ekle"
                                            Width="30" Height="30" Padding="0">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignIconButton}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="TeslimAlindi">
                                                        <Setter Property="Visibility" Value="Hidden"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <materialDesign:PackIcon Kind="CheckCircle" Foreground="#2E7D32"/>
                                    </Button>

                                    <Button Command="{Binding DataContext.DeleteOrderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="Siparişi İptal Et"
                                            Style="{StaticResource MaterialDesignIconButton}"
                                            Width="30" Height="30" Padding="0">
                                        <materialDesign:PackIcon Kind="Delete" Foreground="#C62828"/>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </materialDesign:Card>
    </Grid>
</UserControl>
